# A股桌面宠物 — 环境变量配置
# 复制此文件为 .env 并填入你的密钥（也可在聊天窗口直接粘贴）

# === 大模型 API Keys（至少配置一个）===
# 格式要求: DeepSeek/SiliconFlow/OpenAI 必须是 sk-... 格式
DEEPSEEK_API_KEY=           # DeepSeek API Key（推荐，优先使用）格式: sk-...  长度≥32
SILICON_API_KEY=             # SiliconFlow API Key（故障转移层2）格式: sk-...  长度≥32
# 注: 也支持 SILICONFLOW_API_KEY 变量名（别名）
LINER_API_KEY=               # Liner AI API Key（故障转移层3）长度≥16
BASE44_API_KEY=              # Base44 Agent API Key（故障转移层4）长度≥16
OPENAI_API_KEY=              # OpenAI API Key（故障转移层5）格式: sk-...  长度≥40

# === 交易账号（可选 — dry_run模式无需配置）===
EASTMONEY_ACCOUNT=          # 东方财富账号
EASTMONEY_PASSWORD=         # 东方财富密码
TONGHUASHUN_ACCOUNT=        # 同花顺账号
TONGHUASHUN_PASSWORD=       # 同花顺密码
HTSEC_ACCOUNT=              # 华泰证券账号（XTP量化交易）
HTSEC_PASSWORD=              # 华泰证券密码
BROKER_ID=eastmoney         # 券商标识: eastmoney/ths/htsec

# === 交易模式 ===
# dry_run = 模拟交易（默认，安全！不上真实订单）
# live = 实盘交易（需要券商客户端已登录，会下真实订单！）
TRADING_MODE=dry_run

# === Bytebot 电脑操控服务（可选）===
BYTEBOT_AGENT_URL=          # Bytebot Agent 地址（默认 http://localhost:9991）
BYTEBOT_DESKTOP_URL=        # Bytebot Desktop 守护进程地址（默认 http://localhost:9990）

# === 东方财富数据源（可选 — 异动/龙虎榜/筹码免费，AI分析需API Key）===
EM_API_KEY=                # 东方财富AI SaaS API Key（业绩点评/行业研究/金融问答等）

# === 安全配置 ===
PET_WS_TOKEN=               # WebSocket 认证令牌（生产环境必须设置！）
VAULT_ENCRYPTION_KEY=        # Vault加密主密钥（首次运行自动生成）
VAULT_SALT=                  # Vault加密盐（生产环境请更换！）

# === 计费配置 ===
PLATFORM_WALLET_ADDRESS=     # 平台数字币收款地址（默认: TLyD5v9eTDp3mMzpYT3kprF6WdsUc3W99d，已在数据库中预设）

# === 服务配置 ===
PORT=8000                    # 后端端口