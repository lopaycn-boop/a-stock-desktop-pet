# A股桌面宠物 — 环境变量配置
# 复制此文件为 .env 并填入你的密钥

# === 大模型 API Keys（必须配置至少一个）===
DEEPSEEK_API_KEY=           # DeepSeek API Key（推荐，优先使用）
SILICON_API_KEY=            # SiliconFlow API Key（TTS/语音）
LINER_API_KEY=              # Liner AI API Key（研究能力）
OPENAI_API_KEY=             # OpenAI API Key（备用）

# === 交易账号（可选）===
EASTMONEY_ACCOUNT=          # 东方财富账号
EASTMONEY_PASSWORD=         # 东方财富密码

# === Bytebot 电脑操控服务（可选）===
BYTEBOT_AGENT_URL=          # Bytebot Agent 地址（默认 http://localhost:9991）
BYTEBOT_DESKTOP_URL=        # Bytebot Desktop 守护进程地址（默认 http://localhost:9990）

# === 安全配置 ===
PET_WS_TOKEN=                # WebSocket 认证令牌（生产环境必须设置！）
VAULT_ENCRYPTION_KEY=        # Vault加密主密钥（首次运行自动生成）
VAULT_SALT=                  # Vault加密盐（生产环境请更换！）

# === 服务配置 ===
PORT=8000                    # 后端端口
