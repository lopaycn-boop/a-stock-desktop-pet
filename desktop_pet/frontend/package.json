{
  "name": "xiaotudou-desktop-pet",
  "productName": "小土豆AI桌宠",
  "version": "1.0.0",
  "description": "小土豆 AI 股票操盘手桌宠 — OpenClaw Pi + DeepSeek + Live2D",
  "author": "OpenClaw",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack:win": "node scripts/prepare-embedded-python.js && vite build && electron-builder --win --x64",
    "pack:mac": "node scripts/prepare-embedded-python.js && vite build && electron-builder --mac --x64",
    "pack:linux": "node scripts/prepare-embedded-python.js && vite build && electron-builder --linux --x64",
    "prebuild": "node scripts/prepare-embedded-python.js"
  },
  "build": {
    "appId": "com.xiaotudou.desktop-pet",
    "productName": "小土豆AI桌宠",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "public/**/*",
      "Start.vbs"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__", "!*.pyc"]
      },
      {
        "from": "../../potato",
        "to": "potato",
        "filter": ["**/*", "!__pycache__", "!*.pyc", "!*.db"]
      },
      {
        "from": "../../config",
        "to": "config",
        "filter": ["**/*"]
      },
      {
        "from": "../../schema",
        "to": "schema",
        "filter": ["**/*"]
      },
      {
        "from": "../../.env.example",
        "to": ".env.example"
      },
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*", "!__pycache__", "!*.pyc", "!*.db", "!*.dist-info", "!*.egg-info"]
      },
      {
        "from": "../../data",
        "to": "data",
        "filter": ["*.json", "*.db", "*.sql", "!*.pyc"]
      },
      {
        "from": "../backend/requirements.txt",
        "to": "backend/requirements.txt"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "npmRebuild": false
  },
  "dependencies": {
    "@ricky0123/vad-react": "^0.0.36",
    "@ricky0123/vad-web": "^0.0.30",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "vite": "^6.0.5"
  }
}
